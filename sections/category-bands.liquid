{% for block in section.blocks %}
  <section class="category-band{% if block.settings.reverse %} category-band--reverse{% endif %}"{% if block.settings.anchor_id != blank %} id="{{ block.settings.anchor_id }}"{% endif %} {{ block.shopify_attributes }}>
    <figure class="category-band-photo reveal">
      {% if block.settings.image != blank %}
        <img
          src="{{ block.settings.image | image_url: width: 1400 }}"
          srcset="{{ block.settings.image | image_url: width: 700 }} 700w, {{ block.settings.image | image_url: width: 1400 }} 1400w"
          sizes="(max-width: 760px) 100vw, 55vw"
          alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
          style="object-position: {{ block.settings.focal_x | default: 50 }}% {{ block.settings.focal_y | default: 30 }}%;"
          loading="lazy">
      {% endif %}
    </figure>
    <div class="category-band-copy reveal">
      <p class="eyebrow">{{ block.settings.eyebrow }}</p>
      <h2>{{ block.settings.title }}<br><em>{{ block.settings.title_italic }}</em></h2>
      {% if block.settings.description != blank %}<p>{{ block.settings.description }}</p>{% endif %}
      {% if block.settings.button_text != blank %}
        <a class="btn btn-solid" href="{{ block.settings.button_url }}">{{ block.settings.button_text }}</a>
      {% endif %}
    </div>
  </section>
{% endfor %}

{% schema %}
{
  "name": "Category showcase",
  "settings": [],
  "blocks": [
    {
      "type": "band",
      "name": "Category band",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Photo" },
        { "type": "range", "id": "focal_x", "label": "Focal point — horizontal %", "min": 0, "max": 100, "step": 5, "default": 50 },
        { "type": "range", "id": "focal_y", "label": "Focal point — vertical %", "min": 0, "max": 100, "step": 5, "default": 30 },
        { "type": "checkbox", "id": "reverse", "label": "Photo on the right", "default": false },
        { "type": "text", "id": "anchor_id", "label": "Anchor ID (optional, for menu links)" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Category" },
        { "type": "text", "id": "title", "label": "Heading — line 1", "default": "Modest." },
        { "type": "text", "id": "title_italic", "label": "Heading — line 2 (italic)", "default": "Never muted." },
        { "type": "textarea", "id": "description", "label": "Description" },
        { "type": "text", "id": "button_text", "label": "Button text", "default": "Shop Now" },
        { "type": "url", "id": "button_url", "label": "Button link" }
      ]
    }
  ],
  "presets": [{ "name": "Category showcase" }]
}
{% endschema %}
