{% assign current_variant = product.selected_or_first_available_variant %}

<section class="pdp">
  <p class="breadcrumb reveal">
    <a href="{{ routes.root_url }}">Home</a> <span>/</span>
    {% if product.collections.first %}
      <a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a> <span>/</span>
    {% endif %}
    {{ product.title }}
  </p>

  <div class="pdp-layout">
    <div class="pdp-gallery reveal">
      <div class="pdp-gallery-main">
        <img src="{{ product.featured_image | image_url: width: 1200 }}" alt="{{ product.featured_image.alt | default: product.title | escape }}" id="pdp-main-image">
      </div>
      {% if product.images.size > 1 %}
        <div class="pdp-gallery-thumbs">
          {% for image in product.images %}
            <button type="button" class="pdp-gallery-thumb{% if forloop.first %} is-active{% endif %}" data-src="{{ image | image_url: width: 1200 }}" aria-label="View image {{ forloop.index }}">
              <img src="{{ image | image_url: width: 200 }}" alt="">
            </button>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="pdp-info reveal">
      <p class="eyebrow">{{ product.type | default: product.vendor }}</p>
      <h1>{{ product.title }}</h1>
      <p class="pdp-price" id="pdp-price">
        {{ current_variant.price | money }}
        {% if current_variant.compare_at_price > current_variant.price %}
          <s>{{ current_variant.compare_at_price | money }}</s>
        {% endif %}
      </p>
      <div class="pdp-description">{{ product.description }}</div>
      <p class="pdp-description" style="margin-top: 0.75rem; font-size: 0.9rem; color: var(--ink-soft);">A portion of every order supports humanitarian relief efforts in the Middle East.</p>

      {% form 'product', product, id: 'pdp-form' %}
        <input type="hidden" name="id" id="pdp-variant-id" value="{{ current_variant.id }}">

        {% for option in product.options_with_values %}
          {% assign option_name_down = option.name | downcase %}
          <div class="pdp-option">
            <span class="pdp-option-label">{{ option.name }}{% if option_name_down == 'color' or option_name_down == 'colour' %}<span class="pdp-option-value" data-selected-color>{{ option.selected_value }}</span>{% endif %}</span>
            {% if option_name_down == 'color' or option_name_down == 'colour' %}
              <div class="color-selector" data-option-index="{{ forloop.index0 }}">
                {% for value in option.values %}
                  <button
                    type="button"
                    class="color-swatch{% if option.selected_value == value %} is-active{% endif %}{% if value.swatch.color == blank and value.swatch.image == blank %} color-swatch--js{% endif %}"
                    data-value="{{ value | escape }}"
                    data-color-name="{{ value | escape }}"
                    aria-label="{{ value | escape }}"
                    title="{{ value | escape }}"
                    {% if value.swatch.color %}style="background-color: {{ value.swatch.color }};"{% elsif value.swatch.image %}style="background-image: url('{{ value.swatch.image | image_url: width: 100 }}'); background-size: cover;"{% endif %}
                  ></button>
                {% endfor %}
              </div>
            {% else %}
              <div class="size-selector" data-option-index="{{ forloop.index0 }}">
                {% for value in option.values %}
                  <button type="button" class="size-btn{% if option.selected_value == value %} is-active{% endif %}" data-value="{{ value | escape }}">{{ value }}</button>
                {% endfor %}
              </div>
            {% endif %}
          </div>
        {% endfor %}

        <div class="pdp-option">
          <span class="pdp-option-label">Quantity</span>
          <div class="qty-stepper">
            <button type="button" id="qty-decrease" aria-label="Decrease quantity">&minus;</button>
            <span id="qty-value">1</span>
            <button type="button" id="qty-increase" aria-label="Increase quantity">+</button>
          </div>
        </div>

        {% if section.settings.pre_order_mode %}
          <button type="submit" class="btn btn-solid pdp-add" id="pdp-add-to-bag">
            Pre-Order
          </button>
          {% if section.settings.pre_order_note != blank %}
            <p class="pdp-size-note" style="opacity: 1;">{{ section.settings.pre_order_note }}</p>
          {% endif %}
        {% else %}
          <button type="submit" class="btn btn-solid pdp-add" id="pdp-add-to-bag"{% unless current_variant.available %} disabled{% endunless %}>
            {% if current_variant.available %}Add to Bag{% else %}Sold Out{% endif %}
          </button>
        {% endif %}
        <p class="pdp-size-note" id="pdp-size-note" role="status" aria-live="polite"></p>
      {% endform %}

      <div class="accordion">
        <details>
          <summary>Shipping &amp; Care</summary>
          <p>Ships in 3–5 business days. Hand wash cold or dry clean; hang to dry out of direct sun to protect the colour.</p>
        </details>
        {% if product.description != blank %}
          <details>
            <summary>Description</summary>
            {{ product.description }}
          </details>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% assign related_collection = product.collections.first %}
{% if related_collection %}
  {% assign related_products = related_collection.products | where: 'available' %}
  <section class="related">
    <div class="section-head reveal">
      <p class="eyebrow">You Might Also Like</p>
      <h2>More {{ related_collection.title | downcase }}</h2>
    </div>
    <div class="shop-grid related-grid">
      {% assign shown = 0 %}
      {% for related in related_collection.products %}
        {% if related.handle != product.handle and shown < 4 %}
          {% assign shown = shown | plus: 1 %}
          <a class="product-card" href="{{ related.url }}">
            <span class="product-card-media"><img src="{{ related.featured_image | image_url: width: 600 }}" alt="{{ related.featured_image.alt | default: related.title | escape }}" loading="lazy"></span>
            <span class="product-card-info">
              <span class="product-card-name">{{ related.title }}</span>
              <span class="product-card-meta">{{ related_collection.title }}</span>
              <span class="product-card-price">{{ related.price | money }}</span>
            </span>
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </section>
{% endif %}

<script type="application/json" id="pdp-variant-data">
[
  {% for variant in product.variants %}
    {
      "id": {{ variant.id | json }},
      "available": {{ variant.available | json }},
      "price": {{ variant.price | json }},
      "options": {{ variant.options | json }},
      "featured_image": {% if variant.featured_image %}{{ variant.featured_image | image_url: width: 1200 | json }}{% else %}null{% endif %}
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
</script>

<script>
(function () {
  var product = {
    optionsCount: {{ product.options.size }},
    variants: JSON.parse(document.getElementById('pdp-variant-data').textContent),
    preOrder: {{ section.settings.pre_order_mode | default: false | json }}
  };

  var form = document.getElementById('pdp-form');
  if (!form) return;

  var variantIdInput = document.getElementById('pdp-variant-id');
  var priceEl = document.getElementById('pdp-price');
  var addBtn = document.getElementById('pdp-add-to-bag');
  var sizeNote = document.getElementById('pdp-size-note');
  var mainImage = document.getElementById('pdp-main-image');
  var selected = [];

  var COLOR_MAP = {
    'blush': '#e8c4c0', 'dustyrose': '#c9a0a5', 'dusty rose': '#c9a0a5', 'rosegold': '#e0b8ac', 'rose gold': '#e0b8ac',
    'nude': '#e3bfa5', 'champagne': '#f0dfc5', 'offwhite': '#f5f0e6', 'off white': '#f5f0e6', 'ecru': '#e6dfc8',
    'espresso': '#4a3428', 'espressobrown': '#4a3428', 'espresso brown': '#4a3428', 'chocolate': '#5a3825',
    'lightblue': '#b7c9d9', 'light blue': '#b7c9d9', 'dustyblue': '#a9bccb', 'dusty blue': '#a9bccb',
    'powderblue': '#c6dbe1', 'powder blue': '#c6dbe1', 'babyblue': '#c2e0f2', 'baby blue': '#c2e0f2',
    'skyblue': '#a9d0e8', 'sky blue': '#a9d0e8', 'midnight': '#1f2430', 'midnightblue': '#1f2430',
    'sage': '#a3ac93', 'sagegreen': '#a3ac93', 'sage green': '#a3ac93', 'olivegreen': '#6b6c4a', 'olive green': '#6b6c4a',
    'forest': '#2f4033', 'forestgreen': '#2f4033', 'hunter': '#2b3b2c', 'huntergreen': '#2b3b2c', 'hunter green': '#2b3b2c',
    'emerald': '#3b6255', 'khaki': '#c3b091',
    'taupe': '#b3a394', 'camel': '#c19a6b', 'mocha': '#6f4e37', 'latte': '#a9835f', 'caramel': '#af6e3b', 'toffee': '#7b4a2d',
    'rust': '#a0522d', 'terracotta': '#c1663b', 'brick': '#9c4a3a', 'copper': '#b6774a', 'bronze': '#8c6a3f',
    'burgundy': '#5a2233', 'wine': '#5c2331', 'maroon': '#5a1f26', 'aubergine': '#4a2f3a', 'eggplant': '#4a2f3a', 'plum': '#6d4058',
    'cream': '#f2ead9', 'ivory': '#f5f0e6', 'pearl': '#efe9de', 'oatmeal': '#ddd2bd', 'mushroom': '#c3b7a8', 'greige': '#c2b9ac',
    'sand': '#d9c7a3', 'dune': '#d3c2a0', 'stone': '#b8ac9a', 'charcoal': '#3a3733', 'slate': '#5c6167', 'steel': '#7a8288', 'pewter': '#8e8d8a', 'graphite': '#41403e',
    'clay': '#b8763f', 'mauve': '#b48a9c', 'mustard': '#c9a63c', 'amber': '#c68e2e',
    'coral': '#e08d75', 'peach': '#f0c3a0', 'apricot': '#eab98a'
  };

  function swatchColor(name) {
    var raw = (name || '').trim();
    var key = raw.toLowerCase();
    var noSpace = key.replace(/[\s-]+/g, '');
    if (COLOR_MAP[key]) return COLOR_MAP[key];
    if (COLOR_MAP[noSpace]) return COLOR_MAP[noSpace];
    var probe = document.createElement('span');
    probe.style.color = '';
    probe.style.color = noSpace;
    if (probe.style.color !== '') return noSpace;
    probe.style.color = '';
    probe.style.color = raw;
    if (probe.style.color !== '') return raw;
    return null;
  }

  document.querySelectorAll('.color-swatch--js').forEach(function (swatch) {
    var resolved = swatchColor(swatch.dataset.colorName);
    if (resolved) {
      swatch.style.backgroundColor = resolved;
    } else {
      swatch.classList.add('color-swatch--unknown');
    }
  });

  function selectorGroups(selector, btnClass) {
    document.querySelectorAll(selector).forEach(function (group) {
      var idx = parseInt(group.dataset.optionIndex, 10);
      var active = group.querySelector('.' + btnClass + '.is-active');
      selected[idx] = active ? active.dataset.value : null;

      group.querySelectorAll('.' + btnClass).forEach(function (btn) {
        btn.addEventListener('click', function () {
          group.querySelectorAll('.' + btnClass).forEach(function (b) { b.classList.remove('is-active'); });
          btn.classList.add('is-active');
          selected[idx] = btn.dataset.value;
          sizeNote.textContent = '';
          var valueLabel = group.parentElement.querySelector('[data-selected-color]');
          if (valueLabel) valueLabel.textContent = btn.dataset.value;
          updateVariant();
        });
      });
    });
  }

  selectorGroups('.size-selector', 'size-btn');
  selectorGroups('.color-selector', 'color-swatch');

  function updateVariant() {
    var match = product.variants.find(function (v) {
      return v.options.every(function (opt, i) { return selected[i] == null || opt === selected[i]; });
    });
    if (!match) {
      if (!product.preOrder) {
        addBtn.disabled = true;
        addBtn.textContent = 'Unavailable';
      }
      return;
    }
    variantIdInput.value = match.id;
    priceEl.textContent = (match.price / 100).toLocaleString(undefined, { style: 'currency', currency: '{{ cart.currency.iso_code }}' });
    if (product.preOrder) {
      addBtn.disabled = false;
      addBtn.textContent = 'Pre-Order';
    } else {
      addBtn.disabled = !match.available;
      addBtn.textContent = match.available ? 'Add to Bag' : 'Sold Out';
    }
    if (match.featured_image) {
      mainImage.src = match.featured_image;
      var matchFile = match.featured_image.split('?')[0].split('/').pop();
      document.querySelectorAll('.pdp-gallery-thumb').forEach(function (t) {
        t.classList.toggle('is-active', t.dataset.src.split('?')[0].split('/').pop() === matchFile);
      });
    }
  }

  /* Gallery thumb swap */
  document.querySelectorAll('.pdp-gallery-thumb').forEach(function (thumb) {
    thumb.addEventListener('click', function () {
      document.querySelectorAll('.pdp-gallery-thumb').forEach(function (t) { t.classList.remove('is-active'); });
      thumb.classList.add('is-active');
      mainImage.src = thumb.dataset.src;
    });
  });

  /* Quantity stepper */
  var qty = 1;
  var qtyValue = document.getElementById('qty-value');
  document.getElementById('qty-decrease').addEventListener('click', function () {
    qty = Math.max(1, qty - 1);
    qtyValue.textContent = qty;
  });
  document.getElementById('qty-increase').addEventListener('click', function () {
    qty = Math.min(9, qty + 1);
    qtyValue.textContent = qty;
  });

  form.addEventListener('submit', function (e) {
    e.preventDefault();
    if (product.optionsCount > 0 && selected.some(function (s) { return !s; })) {
      sizeNote.textContent = 'Pick a size before adding to your bag.';
      return;
    }
    if (window.VV_Cart) {
      window.VV_Cart.add(variantIdInput.value, qty);
    }
  });
})();
</script>

{% schema %}
{
  "name": "Product",
  "settings": [
    { "type": "checkbox", "id": "pre_order_mode", "label": "Enable pre-order mode", "info": "Shows a 'Pre-Order' button instead of 'Add to Bag', and keeps it enabled even if the variant is marked out of stock. Turn on 'Continue selling when out of stock' on the product's variants in Shopify Admin for this to work at checkout too.", "default": false },
    { "type": "text", "id": "pre_order_note", "label": "Pre-order note", "default": "Ships within 2-3 weeks." }
  ]
}
{% endschema %}
